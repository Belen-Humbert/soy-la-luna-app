# Copiá este archivo como .env.local y completá tus valores de Supabase
# Los encontrás en: supabase.com → tu proyecto → Settings → API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# NASA API Key — gratis en https://api.nasa.gov
# Sin key funciona igual con DEMO_KEY (limite 30 req/hora)
VITE_NASA_API_KEY=DEMO_KEY
